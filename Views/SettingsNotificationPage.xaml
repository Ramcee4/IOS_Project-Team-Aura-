<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.SettingsNotificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <ScrollView>
        <VerticalStackLayout Padding="24,20,24,24" Spacing="22">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <ImageButton
                    Grid.Column="0"
                    Source="back_icon.png"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    Margin="0,20,5,20"
                    WidthRequest="16"
                    HeightRequest="16"
                    VerticalOptions="Center" />

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Notifications &amp; Reminders" FontSize="28" FontAttributes="Bold" TextColor="#E85B73" />
                    <Label Text="Manage your notification preferences" FontSize="15" TextColor="#6F6A6C" />
                </VerticalStackLayout>
            </Grid>

            <Border Padding="22" BackgroundColor="#F8F8F8" Stroke="#DDD6D8" StrokeThickness="1" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="24">

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#E85B73" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Period Reminder" TextColor="black" FontSize="16" FontAttributes="Bold" />
                                <Label Text="Get notified 2 days before" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="PeriodSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#A7D8AE" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Ovulation Reminder" FontSize="16" TextColor="#222222" FontAttributes="Bold" />
                                <Label Text="Get notified on the day" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="OvulationSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#76C9C2" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Fertile Window Alert" FontSize="16" TextColor="#222222" FontAttributes="Bold" />
                                <Label Text="Get notified when it begins" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="FertileSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#FFC16E" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Daily Symptom Logging" FontSize="16" TextColor="#222222" FontAttributes="Bold" />
                                <Label Text="Reminder at 8:00 PM" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="DailySymptomSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#E85B73" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Medication Reminder" FontSize="16" TextColor="#222222" FontAttributes="Bold" />
                                <Label Text="Take meds on time" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="MedicationSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                    <Border Padding="14" BackgroundColor="#F8F8F8" Stroke="#222222" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="38" HeightRequest="38" BackgroundColor="#A7D8AE" StrokeShape="RoundRectangle 8">
                                <Image Source="notification_icon.png" WidthRequest="22" HeightRequest="22" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Exercise Reminder" FontSize="16" TextColor="#222222" FontAttributes="Bold" />
                                <Label Text="Stay active daily" FontSize="14" TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                            <Switch x:Name="ExerciseSwitch" Toggled="OnSwitchToggled" IsToggled="True" Grid.Column="2" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>