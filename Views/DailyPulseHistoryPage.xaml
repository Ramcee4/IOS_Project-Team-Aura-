<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.DailyPulseHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20,24,20" Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <ImageButton
                        Grid.Column="0"
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        Margin="0,20,5,20"
                        WidthRequest="16"
                        HeightRequest="16"
                        Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            Text="Daily Pulse"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />
                        <Label
                            Text="View your saved daily entries"
                            FontSize="14"
                            TextColor="#6F6A6C" />
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="2"
                        Text="+"
                        FontSize="36"
                        TextColor="#222222">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <VerticalStackLayout
                    x:Name="DailyPulseContainer"
                    Spacing="18" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Padding="18,12,18,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*,*,*,*">
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Home" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="daily_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Daily" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInsightTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="insight_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Insight" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLearnTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="learn_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Learn" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="settings_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Settings" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- CUSTOM ALERT OVERLAYS -->
        <Grid x:Name="AlertOverlay" 
              Grid.RowSpan="2" 
              IsVisible="False" 
              BackgroundColor="#80000000" 
              ZIndex="1000">
            <Border BackgroundColor="White" 
                    StrokeThickness="0" 
                    StrokeShape="RoundRectangle 28" 
                    Padding="30" 
                    VerticalOptions="Center" 
                    HorizontalOptions="Center" 
                    WidthRequest="320">
                <VerticalStackLayout Spacing="20">
                    <Label x:Name="AlertTitle" 
                           FontSize="26" 
                           FontAttributes="Bold" 
                           TextColor="#E85B73" 
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="AlertMessage" 
                           FontSize="15" 
                           TextColor="#444444" 
                           HorizontalTextAlignment="Center" 
                           LineBreakMode="WordWrap" />
                    <Button x:Name="OkButton" 
                            Text="OK" 
                            Clicked="OnOkClicked" 
                            BackgroundColor="#E85B73" 
                            TextColor="White" 
                            CornerRadius="16" 
                            HeightRequest="55" 
                            FontAttributes="Bold" />
                    <Grid x:Name="ConfirmButtons" 
                          ColumnDefinitions="*,*" 
                          ColumnSpacing="12">
                        <Button Grid.Column="0" 
                                Text="No" 
                                Clicked="OnCancelAlertClicked" 
                                BackgroundColor="#F4EDEF" 
                                TextColor="#6F6A6C" 
                                CornerRadius="16" 
                                HeightRequest="55" />
                        <Button Grid.Column="1" 
                                Text="Yes" 
                                Clicked="OnConfirmDeleteClicked" 
                                BackgroundColor="#E85B73" 
                                TextColor="White" 
                                CornerRadius="16" 
                                HeightRequest="55" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>