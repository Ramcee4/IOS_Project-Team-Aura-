<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid x:Name="RootGrid" RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,20,24,20"
                Spacing="18">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <ImageButton
                        Grid.Column="0"
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        Margin="0,20,5,20"
                        WidthRequest="16"
                        HeightRequest="16"
                        Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            Text="Profile"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />

                        <Label
                            Text="Manage your personal information"
                            FontSize="14"
                            TextColor="#6F6A6C" />
                    </VerticalStackLayout>
                </Grid>

                <Border
                    Margin="0,22,0,0"
                    Padding="28,28,28,32"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="18">

                        <Border
                            WidthRequest="90"
                            HeightRequest="90"
                            StrokeThickness="0"
                            BackgroundColor="#F1F1F4"
                            StrokeShape="RoundRectangle 45"
                            HorizontalOptions="Center">

                            <Image
                                Source="profile_icon.png"
                                WidthRequest="50"
                                HeightRequest="50"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Name" FontSize="14" TextColor="#111111" />

                            <Border
                                BackgroundColor="#F1F1F4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="48">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="NameEntry"
                                        Placeholder="Name"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent"
                                        Margin="12,0" />

                                    <Image
                                        Grid.Column="1"
                                        Source="edit_icon.png"
                                        WidthRequest="22"
                                        HeightRequest="22"
                                        Margin="0,0,12,0"
                                        VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditNameClicked" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email" FontSize="14" TextColor="#111111" />

                            <Border
                                BackgroundColor="#F1F1F4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="48">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="EmailEntry"
                                        Placeholder="Email"
                                        Keyboard="Email"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent"
                                        Margin="12,0" />

                                    <Image
                                        Grid.Column="1"
                                        Source="edit_icon.png"
                                        WidthRequest="22"
                                        HeightRequest="22"
                                        Margin="0,0,12,0"
                                        VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditEmailClicked" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" FontSize="14" TextColor="#111111" />

                            <Border
                                BackgroundColor="#F1F1F4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="48">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        x:Name="PasswordEntry"
                                        Placeholder="Password"
                                        IsPassword="True"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent"
                                        Margin="12,0" />

                                    <Image
                                        Grid.Column="1"
                                        Source="edit_icon.png"
                                        WidthRequest="22"
                                        HeightRequest="22"
                                        Margin="0,0,12,0"
                                        VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnEditPasswordClicked" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid
            Grid.Row="1"
            Padding="40,12,40,28"
            ColumnDefinitions="*,20,*"
            BackgroundColor="#F4EDEF">

            <Button
                Grid.Column="0"
                Text="Cancel"
                Clicked="OnCancelClicked"
                HeightRequest="50"
                CornerRadius="8"
                BackgroundColor="#C24E63"
                TextColor="White"
                FontSize="15" />

            <Button
                Grid.Column="2"
                Text="Save"
                Clicked="OnSaveClicked"
                HeightRequest="50"
                CornerRadius="8"
                BackgroundColor="#E85B73"
                TextColor="White"
                FontSize="15" />

        </Grid>

        <!-- CUSTOM ALERT -->
        <Grid
            x:Name="CustomAlertOverlay"
            Grid.RowSpan="2"
            IsVisible="False"
            BackgroundColor="#80000000"
            Padding="30">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24"
                Padding="24"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="320">

                <VerticalStackLayout Spacing="22">

                    <Label
                        x:Name="CustomAlertTitle"
                        Text="Success"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#E85B73"
                        HorizontalTextAlignment="Center" />

                    <Label
                        x:Name="CustomAlertMessage"
                        Text="Profile updated successfully."
                        FontSize="18"
                        TextColor="#333333"
                        HorizontalTextAlignment="Center" />

                    <Button
                        Text="OK"
                        Clicked="OnCustomAlertOkClicked"
                        HeightRequest="56"
                        CornerRadius="14"
                        BackgroundColor="#E85B73"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold" />

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>