<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Team_Aura_Period_Tracker_.Step3Page"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid>
        <VerticalStackLayout
            Padding="28,40,28,28"
            Spacing="0"
            HorizontalOptions="Center"
            VerticalOptions="Fill"
            WidthRequest="390">

            <BoxView HeightRequest="110" Opacity="0" />

            <Border
                HeightRequest="86"
                WidthRequest="86"
                HorizontalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 43">
                <Image Source="logo_icon.png" Aspect="AspectFill" />
            </Border>

            <Label
                Text="Period Tracker"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,8,0,0"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#EA5B73" />

            <VerticalStackLayout Margin="0,12,0,0" Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                </HorizontalStackLayout>

                <Label
                    Text="Step 3 of 6"
                    HorizontalOptions="Center"
                    FontSize="12"
                    TextColor="#8F8A93" />
            </VerticalStackLayout>

            <Border
                Margin="0,18,0,0"
                Padding="28,28,28,24"
                BackgroundColor="#F8F8F8"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24">

                <VerticalStackLayout Spacing="0">

                    <Label
                        Text="Cycle Information"
                        FontSize="26"
                        FontAttributes="Bold"
                        TextColor="#111111"
                        LineBreakMode="WordWrap" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Date of last period" FontSize="14" FontAttributes="Bold" TextColor="#222222" />

                        <Button
                            x:Name="LastPeriodDateButton"
                            Text="Select date"
                            Clicked="OnOpenDatePickerPageClicked"
                            BackgroundColor="#F8F8F8"
                            TextColor="#222222"
                            BorderColor="#111111"
                            BorderWidth="1"
                            CornerRadius="12"
                            HeightRequest="40" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Typical cycle length (days)" FontSize="14" FontAttributes="Bold" TextColor="#222222" />

                        <Border
                            BackgroundColor="#F8F8F8"
                            Stroke="#111111"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="12,0">
                            <Entry
                                x:Name="CycleLengthEntry"
                                Placeholder="e.g. 28"
                                PlaceholderColor="#8F8A93"
                                Keyboard="Numeric"
                                TextColor="#222222"
                                BackgroundColor="Transparent"
                                HeightRequest="40" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Period days" FontSize="14" FontAttributes="Bold" TextColor="#222222" />

                        <Border
        BackgroundColor="#F8F8F8"
        Stroke="#111111"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        Padding="12,0">

                            <Entry
            x:Name="PeriodDaysEntry"
            Placeholder="e.g. 5"
            PlaceholderColor="#8F8A93"
            Keyboard="Numeric"
            TextColor="#222222"
            BackgroundColor="Transparent"
            HeightRequest="40" />
                        </Border>
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Cycle Type" FontSize="14" FontAttributes="Bold" TextColor="#222222" />

                        <Grid ColumnDefinitions="*,10,*">
                            <Button
                                x:Name="RegularButton"
                                Grid.Column="0"
                                Text="Regular"
                                Clicked="OnCycleTypeClicked"
                                BackgroundColor="#F8F8F8"
                                TextColor="#222222"
                                BorderColor="#111111"
                                BorderWidth="1"
                                CornerRadius="12"
                                HeightRequest="42" />

                            <Button
                                x:Name="IrregularButton"
                                Grid.Column="2"
                                Text="Irregular"
                                Clicked="OnCycleTypeClicked"
                                BackgroundColor="#F8F8F8"
                                TextColor="#222222"
                                BorderColor="#111111"
                                BorderWidth="1"
                                CornerRadius="12"
                                HeightRequest="42" />
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Grid Margin="0,18,0,0" ColumnDefinitions="*,14,*" ColumnSpacing="0">
                <Button
                    Grid.Column="0"
                    Text="Back"
                    Clicked="OnBackClicked"
                    HeightRequest="50"
                    CornerRadius="10"
                    BackgroundColor="#C24E63"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold" />

                <Button
                    Grid.Column="2"
                    Text="Next"
                    Clicked="OnNextClicked"
                    HeightRequest="50"
                    CornerRadius="10"
                    BackgroundColor="#E85B73"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold" />
            </Grid>
        </VerticalStackLayout>

        <!-- CUSTOM ALERT -->
        <Grid
            x:Name="CustomAlertOverlay"
            IsVisible="False"
            BackgroundColor="#80000000"
            Padding="30"
            ZIndex="99">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 22"
                Padding="24"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="310">

                <VerticalStackLayout Spacing="18">
                    <Label
                        x:Name="CustomAlertTitle"
                        Text="Required"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#E85B73"
                        HorizontalTextAlignment="Center" />

                    <Label
                        x:Name="CustomAlertMessage"
                        Text="Message here"
                        FontSize="16"
                        TextColor="#4A4A4A"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap" />

                    <Button
                        Text="OK"
                        Clicked="OnCustomAlertOkClicked"
                        Margin="0,8,0,0"
                        HeightRequest="48"
                        CornerRadius="12"
                        BackgroundColor="#E85B73"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>