<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.LearnPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,50,24,20"
                Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <ImageButton
                        Grid.Column="0"
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        Margin="0,20,0,0"
                        BackgroundColor="Transparent"
                        WidthRequest="20"
                        HeightRequest="20"
                        HorizontalOptions="Start"
                        VerticalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                        <Label
                            Text="Educational Hub"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />

                        <Label
                            Text="Learn from medical experts about reproductive health"
                            Margin="0,6,0,0"
                            FontSize="14"
                            TextColor="#6F6A6C"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                </Grid>

                <!-- Filter Buttons -->
                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="12">

                    <Button
                        x:Name="AllButton"
                        Text="All"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F4CDD5"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#333333"
                        FontSize="13" />

                    <Button
                        x:Name="CycleHealthButton"
                        Text="Cycle Health"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F8F8F8"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#666666"
                        FontSize="13" />

                    <Button
                        x:Name="ConditionsButton"
                        Text="Conditions"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F8F8F8"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#666666"
                        FontSize="13" />

                </HorizontalStackLayout>

                <!-- Article 1 -->
                <Border
                    Padding="16,14,16,18"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnArticleOneTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="22">

                        <Grid ColumnDefinitions="Auto,Auto,* ,Auto" ColumnSpacing="8">

                            <Border
                                Grid.Column="0"
                                Padding="14,4"
                                BackgroundColor="#F8F8F8"
                                Stroke="#222222"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">

                                <Label
                                    Text="Cycle Health"
                                    FontSize="13"
                                    TextColor="#E85B73"
                                    HorizontalTextAlignment="Center" />
                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="8min"
                                FontSize="13"
                                TextColor="#666666"
                                VerticalTextAlignment="Center" />

                            <Label
                                Grid.Column="3"
                                Text="›"
                                FontSize="30"
                                TextColor="#222222"
                                VerticalTextAlignment="Center" />

                        </Grid>

                        <Label
                            Text="Understanding Your&#10;Menstrual Cycle"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#666666"
                            LineHeight="0.9" />

                        <Label
                            Text="Learn about the four phases of your cycle and how hormones affect your body and mood"
                            FontSize="14"
                            TextColor="#6F6A6C"
                            LineHeight="1.35" />

                    </VerticalStackLayout>
                </Border>

                <!-- Article 2 -->
                <Border
                    Padding="16,14,16,18"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnArticleTwoTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="22">

                        <Grid ColumnDefinitions="Auto,Auto,* ,Auto" ColumnSpacing="8">

                            <Border
                                Grid.Column="0"
                                Padding="14,4"
                                BackgroundColor="#F8F8F8"
                                Stroke="#222222"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">

                                <Label
                                    Text="Conditions"
                                    FontSize="13"
                                    TextColor="#E85B73"
                                    HorizontalTextAlignment="Center" />
                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="12min"
                                FontSize="13"
                                TextColor="#666666"
                                VerticalTextAlignment="Center" />

                            <Label
                                Grid.Column="3"
                                Text="›"
                                FontSize="30"
                                TextColor="#222222"
                                VerticalTextAlignment="Center" />

                        </Grid>

                        <Label
                            Text="Managing PCOS Naturally"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#666666" />

                        <Label
                            Text="Evidence- based strategies for managing polycystic ovary syndrome through lifestyle and nutrition."
                            FontSize="14"
                            TextColor="#6F6A6C"
                            LineHeight="1.35" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Border
            Grid.Row="1"
            BackgroundColor="White"
            StrokeThickness="0"
            Padding="18,12,18,10">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Home" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="daily_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Daily" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInsightTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="insight_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Insight" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLearnTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="learn_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Learn" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="settings_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Settings" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>