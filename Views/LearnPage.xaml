<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.LearnPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid x:Name="RootGrid" RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20,24,20" Spacing="18">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <ImageButton
                        Grid.Column="0"
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        Margin="0,20,5,20"
                        WidthRequest="16"
                        HeightRequest="16"
                        Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            Text="Educational Hub"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />

                        <Label
                            Text="Learn from medical experts about reproductive health"
                            FontSize="14"
                            TextColor="#6F6A6C"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Grid>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                    <Button
                        x:Name="AllButton"
                        Text="All"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F4CDD5"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#333333"
                        FontSize="13" />

                    <Button
                        x:Name="CycleHealthButton"
                        Text="Cycle Health"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F8F8F8"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#666666"
                        FontSize="13" />

                    <Button
                        x:Name="ConditionsButton"
                        Text="Conditions"
                        Clicked="OnFilterClicked"
                        HeightRequest="34"
                        Padding="18,0"
                        CornerRadius="17"
                        BackgroundColor="#F8F8F8"
                        BorderColor="#222222"
                        BorderWidth="1"
                        TextColor="#666666"
                        FontSize="13" />
                </HorizontalStackLayout>

                <VerticalStackLayout
                    x:Name="LessonsContainer"
                    Spacing="18" />

            </VerticalStackLayout>
        </ScrollView>

        <Border
            Grid.Row="1"
            BackgroundColor="White"
            StrokeThickness="0"
            Padding="18,12,18,10">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Home" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="daily_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Daily" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInsightTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="insight_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Insight" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <Image Source="learn_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Learn" FontSize="12" TextColor="#E85B73" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="settings_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Settings" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>