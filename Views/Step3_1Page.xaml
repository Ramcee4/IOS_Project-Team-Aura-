<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Team_Aura_Period_Tracker_.Step3_1Page"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout
            Grid.Row="0"
            Padding="28,40,28,20"
            Spacing="0"
            HorizontalOptions="Center"
            VerticalOptions="Fill"
            WidthRequest="390">

            <BoxView HeightRequest="110" Opacity="0" />

            <Border
                HeightRequest="86"
                WidthRequest="86"
                HorizontalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 43">
                <Image Source="logo_icon.png" Aspect="AspectFill" />
            </Border>

            <Label
                Text="Period Tracker"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,8,0,0"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#EA5B73" />

            <VerticalStackLayout Margin="0,8,0,0" Spacing="6">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                    <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#CFCBEE" />
                </HorizontalStackLayout>
                <Label Text="Step 3 of 6" HorizontalOptions="Center" FontSize="12" TextColor="#8F8A93" />
            </VerticalStackLayout>

            <Border
                Margin="0,18,0,0"
                Padding="18,18,18,18"
                BackgroundColor="#F8F8F8"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24"
                HeightRequest="375">

                <VerticalStackLayout Spacing="14">
                    <Border
                        Padding="14,14,14,16"
                        BackgroundColor="#F8F8F8"
                        Stroke="#D8D8D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">

                        <VerticalStackLayout Spacing="10">
                            <!-- Header Calendar with Custom Selectors -->
                            <Grid ColumnDefinitions="40,*,*,40" VerticalOptions="Center">
                                <Button Grid.Column="0" Text="‹" Clicked="OnPreviousMonthClicked" BackgroundColor="Transparent" TextColor="#222222" FontSize="26" />

                                <Label Grid.Column="1" x:Name="MonthLabel" Text="Jan" FontSize="16" FontAttributes="Bold" TextColor="#E85B73" HorizontalTextAlignment="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMonthLabelTapped" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Label Grid.Column="2" x:Name="YearLabel" Text="2026" FontSize="16" FontAttributes="Bold" TextColor="#E85B73" HorizontalTextAlignment="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnYearLabelTapped" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Button Grid.Column="3" Text="›" Clicked="OnNextMonthClicked" BackgroundColor="Transparent" TextColor="#222222" FontSize="26" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4">
                                <Label Grid.Column="0" Text="Su" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="1" Text="Mo" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="2" Text="Tu" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="3" Text="We" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="4" Text="Th" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="5" Text="Fr" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                                <Label Grid.Column="6" Text="Sa" HorizontalTextAlignment="Center" FontSize="12" TextColor="#8A8A8A" />
                            </Grid>

                            <Grid x:Name="CalendarGrid" ColumnDefinitions="*,*,*,*,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="4" RowSpacing="10" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Margin="0,18,0,0" ColumnDefinitions="*,14,*" Padding="28,10,28,20" BackgroundColor="#F4EDEF">
            <Button Grid.Column="0" Text="Back" Clicked="OnBackClicked" HeightRequest="50" CornerRadius="10" BackgroundColor="#C24E63" TextColor="White" FontSize="17" FontAttributes="Bold" />
            <Button Grid.Column="2" Text="Save" Clicked="OnNextClicked" HeightRequest="50" CornerRadius="10" BackgroundColor="#E85B73" TextColor="White" FontSize="17" FontAttributes="Bold" />
        </Grid>

        <!-- CUSTOM SELECTION ALERT (Consistent Pink Design) -->
        <Grid x:Name="SelectionOverlay" Grid.RowSpan="2" IsVisible="False" BackgroundColor="#80000000" ZIndex="1000">
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="24" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="320" HeightRequest="450">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="15">
                    <Label Grid.Row="0" x:Name="SelectionTitle" Text="Select Month" FontSize="24" FontAttributes="Bold" TextColor="#E85B73" HorizontalTextAlignment="Center" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout x:Name="SelectionContainer" Spacing="2" />
                    </ScrollView>
                    <Button Grid.Row="2" Text="Cancel" Clicked="OnCancelSelectionClicked" BackgroundColor="#F4EDEF" TextColor="#6F6A6C" CornerRadius="16" HeightRequest="50" FontAttributes="Bold" FontSize="15"/>
                </Grid>
            </Border>
        </Grid>

        <!-- REQUIRED/ERROR ALERT -->
        <Grid x:Name="CustomAlertOverlay" Grid.RowSpan="2" IsVisible="False" BackgroundColor="#80000000" ZIndex="1100">
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 28" Padding="30" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="320">
                <VerticalStackLayout Spacing="20">
                    <Label x:Name="CustomAlertTitle" FontSize="24" FontAttributes="Bold" TextColor="#E85B73" HorizontalTextAlignment="Center" />
                    <Label x:Name="CustomAlertMessage" FontSize="16" TextColor="#4A4A4A" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                    <Button Text="OK" Clicked="OnCustomAlertOkClicked" HeightRequest="55" CornerRadius="16" BackgroundColor="#E85B73" TextColor="White" FontSize="15" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>