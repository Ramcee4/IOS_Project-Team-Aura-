<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.OtpVerificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid>

        <VerticalStackLayout Padding="32" Spacing="20" VerticalOptions="Center">

            <Label
                Text="Verify OTP"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#E85B73"
                HorizontalTextAlignment="Center" />

            <Label
                Text="Enter the code sent to your email"
                FontSize="16"
                TextColor="#6F6A6C"
                HorizontalTextAlignment="Center" />

            <Label Text="OTP Code" FontSize="15" FontAttributes="Bold" TextColor="#111111" />

            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 16" HeightRequest="58">
                <Entry
                    x:Name="OtpEntry"
                    Placeholder="Enter OTP"
                    Keyboard="Numeric"
                    MaxLength="6"
                    TextColor="#222222"
                    PlaceholderColor="#8A8A8A"
                    BackgroundColor="Transparent"
                    Margin="16,0" />
            </Border>

            <Button
                Text="Verify"
                Clicked="OnVerifyOtpClicked"
                HeightRequest="58"
                CornerRadius="16"
                BackgroundColor="#E85B73"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold" />

            <Button
    Text="Resend OTP"
    Clicked="OnResendOtpClicked"
    BackgroundColor="Transparent"
    TextColor="#E85B73"
    FontSize="16"
    FontAttributes="Bold" />

            <Button
                Text="Back"
                Clicked="OnBackClicked"
                BackgroundColor="Transparent"
                TextColor="#C24E63"
                FontSize="16" />

        </VerticalStackLayout>

        <Grid
            x:Name="CustomAlertOverlay"
            IsVisible="False"
            BackgroundColor="#99000000"
            Padding="35">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28"
                Padding="28"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="24">

                    <Label
                        x:Name="CustomAlertTitle"
                        Text="Success"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="#E85B73"
                        HorizontalTextAlignment="Center" />

                    <Label
                        x:Name="CustomAlertMessage"
                        Text="OTP verified successfully."
                        FontSize="18"
                        TextColor="#333333"
                        HorizontalTextAlignment="Center" />

                    <Button
                        Text="OK"
                        Clicked="OnCustomAlertOkClicked"
                        HeightRequest="58"
                        CornerRadius="16"
                        BackgroundColor="#E85B73"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold" />

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>