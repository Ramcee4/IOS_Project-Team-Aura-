<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.InsightPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20,24,20" Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="36,*" ColumnSpacing="6">
                    <ImageButton
                        Grid.Column="0"
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        Margin="0,20,0,20"
                        WidthRequest="16"
                        HeightRequest="16"
                        Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                        <Label
                            Text="Cycle Insights"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />

                        <Label
                            Text="Understand your pattern"
                            FontSize="14"
                            TextColor="#6F6A6C" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Current Phase -->
                <Border
                    Padding="16"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="Current Phase"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <!-- 🔥 DYNAMIC -->
                        <Label
                            x:Name="PhaseLabel"
                            Text="—"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <!-- 🔥 DYNAMIC -->
                        <Label
                            x:Name="DayLabel"
                            Text="—"
                            FontSize="13"
                            TextColor="#7A7A7A" />

                        <!-- 🔥 OPTIONAL TIP -->
                        <Label
                            x:Name="PhaseTipLabel"
                            Text="—"
                            FontSize="13"
                            TextColor="#6F6A6C" />

                    </VerticalStackLayout>
                </Border>

                <!-- What's Next -->
                <Border
                    Padding="16"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="14">

                        <Label
                            Text="What’s Next"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <!-- Ovulation -->
                        <Border
                            Padding="14"
                            BackgroundColor="#F8F8F8"
                            Stroke="#8F8A93"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16">

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="Ovulation"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#333333" />

                                <!-- 🔥 DYNAMIC -->
                                <Label
                                    x:Name="OvulationLabel"
                                    Text="—"
                                    FontSize="13"
                                    TextColor="#6F6A6C" />

                                <Label
                                    Text="Peak fertility window"
                                    FontSize="13"
                                    TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Next Period -->
                        <Border
                            Padding="14"
                            BackgroundColor="#F8F8F8"
                            Stroke="#8F8A93"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16">

                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="Next Period"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="#333333" />

                                <!-- 🔥 DYNAMIC -->
                                <Label
                                    x:Name="NextPeriodLabel"
                                    Text="—"
                                    FontSize="13"
                                    TextColor="#6F6A6C" />

                                <Label
                                    Text="Prepare your body"
                                    FontSize="13"
                                    TextColor="#6F6A6C" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation (UNCHANGED) -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Padding="18,12,18,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Home" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="daily_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Daily" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                       
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="insight_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Insight" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLearnTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="learn_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Learn" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="settings_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Settings" FontSize="12" TextColor="#111111" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>