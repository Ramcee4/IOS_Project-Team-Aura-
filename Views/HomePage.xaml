<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,50,24,20"
                Spacing="0">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label
                            Text="Hello,"
                            FontSize="16"
                            TextColor="#6F6A6C" />

                        <Label
    x:Name="UserNameLabel"
    Text="User!"
    FontSize="28"
    FontAttributes="Bold"
    TextColor="#E85B73"
    LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <ImageButton
                        Grid.Column="1"
                        Source="bell_icon.png"
                        Clicked="OnBellClicked"
                        BackgroundColor="Transparent"
                        WidthRequest="50"
                        HeightRequest="50"
                        HorizontalOptions="End"
                        VerticalOptions="Center" />
                </Grid>

                <!-- Stats -->
                <Grid
                    Margin="0,28,0,0"
                    ColumnDefinitions="*,12,*">

                    <Border
                        Grid.Column="0"
                        Padding="16,14"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCycleLengthTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8">
                                <BoxView
                                    WidthRequest="8"
                                    HeightRequest="8"
                                    CornerRadius="4"
                                    Color="#95C79A"
                                    VerticalOptions="Center" />
                                <Label
                                    Text="Cycle Length"
                                    FontSize="13"
                                    TextColor="#8A8A8A" />
                            </HorizontalStackLayout>

                            <Label
                                Text="28"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#333333" />

                            <Label
                                Text="days average"
                                FontSize="12"
                                TextColor="#6F6A6C" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16,14"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPeriodDaysTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="8">
                                <BoxView
                                    WidthRequest="8"
                                    HeightRequest="8"
                                    CornerRadius="4"
                                    Color="#F2BC66"
                                    VerticalOptions="Center" />
                                <Label
                                    Text="Period Days"
                                    FontSize="13"
                                    TextColor="#8A8A8A" />
                            </HorizontalStackLayout>

                            <Label
                                Text="5"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#333333" />

                            <Label
                                Text="days average"
                                FontSize="12"
                                TextColor="#6F6A6C" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Quick Actions -->
                <Label
                    Text="Quick Actions"
                    Margin="0,22,0,14"
                    FontSize="17"
                    FontAttributes="Bold"
                    TextColor="#333333" />

                <Grid
                    ColumnDefinitions="*,18,*"
                    RowDefinitions="Auto,18,Auto">

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogTodayTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Image
                                Source="heart_outline.png"
                                WidthRequest="36"
                                HeightRequest="36" />
                            <Label
                                Text="Log Today"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="2"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInsightsTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Image
                                Source="insight_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />
                            <Label
                                Text="Insights"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnJournalTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Image
                                Source="journal_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />
                            <Label
                                Text="Journal"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLearnTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Image
                                Source="learn_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />
                            <Label
                                Text="Learn"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

               <!-- What's Coming -->
<Border
    Margin="0,24,0,0"
    Padding="28,22"
    BackgroundColor="#FFFFFF"
    Stroke="#DDD6D8"
    StrokeThickness="1"
    StrokeShape="RoundRectangle 14">

    <VerticalStackLayout Spacing="20">

        <Label
            Text="What’s Coming"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="#333333" />

        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Fertile Window"
                    FontSize="14"
                    TextColor="#333333" />

                <Label
                    Text="In 5 days"
                    FontSize="14"
                    TextColor="#9A9A9A" />
            </VerticalStackLayout>

            <Label
                Grid.Column="1"
                Text="Day 17–19"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="#333333"
                VerticalOptions="Center" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Next Period"
                    FontSize="14"
                    TextColor="#333333" />

                <Label
                    Text="In 16 days"
                    FontSize="14"
                    TextColor="#9A9A9A" />
            </VerticalStackLayout>

            <Label
                Grid.Column="1"
                Text="Day 28"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="#333333"
                VerticalOptions="Center" />
        </Grid>

    </VerticalStackLayout>
</Border>

<!-- Did You Know -->
<Border
    Margin="0,26,0,20"
    Padding="28,24"
    BackgroundColor="#E8DADB"
    StrokeThickness="0"
    StrokeShape="RoundRectangle 14">

    <VerticalStackLayout Spacing="28">

        <Label
            Text="Did You Know?"
            FontSize="20"
            FontAttributes="Bold"
            TextColor="#333333" />

        <Label
            Text="Your cycle has four distinct phases, each with a unique hormonal patterns. Understanding them helps you work with your body, not against it."
            FontSize="14"
            TextColor="#7A7476"
            LineBreakMode="WordWrap" />

    </VerticalStackLayout>
</Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Border
            Grid.Row="1"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24,24,0,0"
            Padding="18,12,18,10">

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout
                    Grid.Column="0"
                    Spacing="4"
                    HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="home_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Home" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="4"
                    HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="daily_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Daily" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="2"
                    Spacing="4"
                    HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInsightNavTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="insight_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Insight" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="3"
                    Spacing="4"
                    HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLearnNavTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="learn_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Learn" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="4"
                    Spacing="4"
                    HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="settings_icon.png" WidthRequest="26" HeightRequest="26" />
                    <Label Text="Settings" FontSize="12" TextColor="#111111" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>