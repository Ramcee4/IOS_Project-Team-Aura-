<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,30,24,20"
                Spacing="0">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label
            Text="Hello,"
            FontSize="16"
            TextColor="#6F6A6C" />

                        <Label
            x:Name="UserNameLabel"
            Text="User!"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="#E85B73"
            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Grid Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" WidthRequest="50" HeightRequest="50">
                        <ImageButton
            Source="bell_icon.png"
            Clicked="OnBellClicked"
            BackgroundColor="Transparent"
            WidthRequest="50"
            HeightRequest="50"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

                        <Border x:Name="NotificationDot"
                IsVisible="False" 
                WidthRequest="12"
                HeightRequest="12"
                BackgroundColor="#FF0000"
                StrokeThickness="0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,8,8,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Margin="0,28,0,0" ColumnDefinitions="*,15,*">

                    <Border
                        Grid.Column="0"
                        Padding="15,14"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCycleLengthTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="8">

                            <HorizontalStackLayout Spacing="8">
                                <Border
                                    WidthRequest="28"
                                    HeightRequest="28"
                                    BackgroundColor="#E7F5EA"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">

                                    <Label
                                        Text="↻"
                                        FontSize="17"
                                        TextColor="#5CA66A"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>

                                <Label
                                    Text="Cycle Length"
                                    FontSize="13"
                                    TextColor="#8A8A8A"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label
                                x:Name="CycleLengthValueLabel"
                                Text="28"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#333333" />

                            <Label
                                x:Name="CycleLengthSubtitleLabel"
                                Text="days average"
                                FontSize="12"
                                TextColor="#6F6A6C" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16,14"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPeriodDaysTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="8">

                            <HorizontalStackLayout Spacing="8">
                                <Border
                                    WidthRequest="28"
                                    HeightRequest="28"
                                    BackgroundColor="#FFF1D8"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14">

                                    <Label
                                        Text="●"
                                        FontSize="16"
                                        TextColor="#F2A83B"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>

                                <Label
                                    Text="Period Days"
                                    FontSize="13"
                                    TextColor="#8A8A8A"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label
                                x:Name="PeriodDaysValueLabel"
                                Text="5"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#333333" />

                            <Label
                                x:Name="PeriodDaysSubtitleLabel"
                                Text="days average"
                                FontSize="12"
                                TextColor="#6F6A6C" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Margin="0,22,0,14" ColumnDefinitions="*,Auto">

                    <Label
                        Text="Quick Actions"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#333333"
                        VerticalOptions="Center" />

                    <Border
                        Grid.Column="1"
                        Padding="12,6"
                        BackgroundColor="#E85B73"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        VerticalOptions="Center">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStartPeriodTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="0">

                            <Label
                                Text="Start Period"
                                FontSize="11"
                                TextColor="White"
                                HorizontalTextAlignment="Center" />

                            <Label
                                x:Name="StartPeriodCountdownLabel"
                                Text="--"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalTextAlignment="Center" />

                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid
                    ColumnDefinitions="*,15,*"
                    RowDefinitions="Auto,18,Auto">

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogTodayTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image
                                Source="heart_outline.png"
                                WidthRequest="36"
                                HeightRequest="36" />

                            <Label
                                Text="Log Today"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="2"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnInsightsTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image
                                Source="insight_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />

                            <Label
                                Text="Insights"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnJournalTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image
                                Source="journal_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />

                            <Label
                                Text="Journal"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="18"
                        BackgroundColor="#F8F8F8"
                        Stroke="#DDD6D8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="120">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLearnTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout
                            Spacing="10"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Image
                                Source="learn_icon.png"
                                WidthRequest="36"
                                HeightRequest="36" />

                            <Label
                                Text="Learn"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border
                    Margin="0,24,0,0"
                    Padding="28,22"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14">

                    <VerticalStackLayout Spacing="20">

                        <Label
                            Text="What’s Coming"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="1">
                                <Label
                                    Text="Fertile Window"
                                    FontSize="14"
                                    TextColor="#333333" />

                                <Label
                                    x:Name="FertileWindowCountdownLabel"
                                    Text="In 5 days"
                                    FontSize="14"
                                    TextColor="#9A9A9A" />
                            </VerticalStackLayout>

                            <Label
                                x:Name="FertileWindowDayLabel"
                                Grid.Column="1"
                                Text="Day 17–19"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="1">
                                <Label
                                    Text="Next Period"
                                    FontSize="14"
                                    TextColor="#333333" />

                                <Label
                                    x:Name="NextPeriodCountdownLabel"
                                    Text="In 16 days"
                                    FontSize="14"
                                    TextColor="#9A9A9A" />
                            </VerticalStackLayout>

                            <Label
                                x:Name="NextPeriodDayLabel"
                                Grid.Column="1"
                                Text="Day 28"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#333333"
                                VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <Border
                    Margin="0,26,0,20"
                    Padding="28,24"
                    BackgroundColor="#E8DADB"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14">

                    <VerticalStackLayout Spacing="28">

                        <Label
                            Text="Did You Know?"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <Label
                            Text="Your cycle has four distinct phases, each with unique hormonal patterns. Understanding them helps you work with your body, not against it."
                            FontSize="14"
                            TextColor="#7A7476"
                            LineBreakMode="WordWrap" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border
            Grid.Row="1"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24,24,0,0"
            Padding="18,12,18,10">

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout
                    Grid.Column="0"
                    Spacing="4"
                    HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Image
                        Source="home_icon.png"
                        WidthRequest="26"
                        HeightRequest="26" />

                    <Label
                        Text="Home"
                        FontSize="12"
                        TextColor="#E85B73"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="4"
                    HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Image
                        Source="daily_icon.png"
                        WidthRequest="26"
                        HeightRequest="26" />

                    <Label
                        Text="Daily"
                        FontSize="12"
                        TextColor="#111111"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="2"
                    Spacing="4"
                    HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInsightNavTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Image
                        Source="insight_icon.png"
                        WidthRequest="26"
                        HeightRequest="26" />

                    <Label
                        Text="Insight"
                        FontSize="12"
                        TextColor="#111111"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="3"
                    Spacing="4"
                    HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLearnNavTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Image
                        Source="learn_icon.png"
                        WidthRequest="26"
                        HeightRequest="26" />

                    <Label
                        Text="Learn"
                        FontSize="12"
                        TextColor="#111111"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="4"
                    Spacing="4"
                    HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Image
                        Source="settings_icon.png"
                        WidthRequest="26"
                        HeightRequest="26" />

                    <Label
                        Text="Settings"
                        FontSize="12"
                        TextColor="#111111"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>

        <Grid x:Name="StartPeriodAlertOverlay" 
      Grid.RowSpan="2" 
      IsVisible="False" 
      BackgroundColor="#80000000" 
      ZIndex="999">

            <Border BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 28"
            Padding="30"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="320">

                <VerticalStackLayout Spacing="20">

                    <Label Text="🌸" 
                   FontSize="60" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,-10"/>

                    <Label Text="Start Period?" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   TextColor="#E85B73" 
                   HorizontalTextAlignment="Center" />

                    <Label Text="Are you sure you want to log your period start today? This will update your cycle data." 
                   FontSize="15" 
                   TextColor="#444444" 
                   HorizontalTextAlignment="Center" 
                   LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">

                        <Button Grid.Column="0"
                        Text="Cancel" 
                        Clicked="OnCancelAlertClicked" 
                        BackgroundColor="#F4EDEF" 
                        TextColor="#6F6A6C" 
                        CornerRadius="16" 
                        HeightRequest="55" 
                        FontAttributes="Bold" 
                        FontSize="15"/>

                        <Button Grid.Column="1"
                        Text="Yes" 
                        Clicked="OnConfirmStartClicked" 
                        BackgroundColor="#E85B73" 
                        TextColor="White" 
                        CornerRadius="16" 
                        HeightRequest="55" 
                        FontAttributes="Bold" 
                        FontSize="15"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="StatInfoAlertOverlay" 
      Grid.RowSpan="2" 
      IsVisible="False" 
      BackgroundColor="#80000000" 
      ZIndex="1000">

            <Border BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 28"
            Padding="30"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="320">

                <VerticalStackLayout Spacing="20">
                    <Label x:Name="StatAlertEmoji"
                   Text="ℹ️" 
                   FontSize="50" 
                   HorizontalOptions="Center" />

                    <Label x:Name="StatAlertTitle"
                   Text="Information" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#E85B73" 
                   HorizontalTextAlignment="Center" />

                    <Label x:Name="StatAlertMessage"
                   Text="Description goes here." 
                   FontSize="15" 
                   TextColor="#444444" 
                   HorizontalTextAlignment="Center" 
                   LineBreakMode="WordWrap" />

                    <Button Text="OK" 
                    Clicked="OnCloseStatAlertClicked" 
                    BackgroundColor="#E85B73" 
                    TextColor="White" 
                    CornerRadius="16" 
                    HeightRequest="50" 
                    FontAttributes="Bold" 
                    FontSize="15"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>