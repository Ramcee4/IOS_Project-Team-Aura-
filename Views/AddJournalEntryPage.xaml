<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.AddJournalEntryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,50,24,20"
                Spacing="18">

                <!-- HEADER -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <ImageButton
                        Source="back_icon.png"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        WidthRequest="20"
                        HeightRequest="20" />

                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            Text="Health Journal"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#E85B73" />

                        <Label
                            Text="Track your health pattern"
                            FontSize="14"
                            TextColor="#6F6A6C" />
                    </VerticalStackLayout>

                </Grid>

                <!-- FORM CARD -->
                <Border
                    Padding="20"
                    BackgroundColor="#F8F8F8"
                    Stroke="#DDD6D8"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="16">

                        <Label
                            Text="New Entry"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#333333" />

                        <!-- TITLE -->
                        <VerticalStackLayout>
                            <Label Text="Title" FontSize="12" TextColor="#8A8A8A" />

                            <Border Stroke="#222" StrokeShape="RoundRectangle 14" Padding="12,0">
                                <Entry
                                    x:Name="TitleEntry"
                                    Placeholder="e.g. day 5 of Cycle"
                                    TextColor="#222222"
                                    PlaceholderColor="#8A8A8A"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- MOOD + ENERGY -->
                        <Grid ColumnDefinitions="*,16,*">

                            <VerticalStackLayout>
                                <Label Text="Mood" FontSize="12" TextColor="#8A8A8A" />

                                <Border Stroke="#222" StrokeShape="RoundRectangle 14" Padding="12,0">
                                    <Entry
                                        x:Name="MoodEntry"
                                        Placeholder="tired"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2">
                                <Label
                                    x:Name="EnergyLabel"
                                    Text="Energy (5/10)"
                                    FontSize="12"
                                    TextColor="#8A8A8A" />

                                <Slider
                                    x:Name="EnergySlider"
                                    Minimum="0"
                                    Maximum="10"
                                    Value="5"
                                    ValueChanged="OnEnergyChanged"
                                    MinimumTrackColor="#6C52A7"
                                    MaximumTrackColor="#D8CCE8"
                                    ThumbColor="#6C52A7" />
                            </VerticalStackLayout>

                        </Grid>

                        <!-- SLEEP + EXERCISE -->
                        <Grid ColumnDefinitions="*,16,*">

                            <VerticalStackLayout>
                                <Label Text="Sleep hours" FontSize="12" TextColor="#8A8A8A" />

                                <Border Stroke="#222" StrokeShape="RoundRectangle 14" Padding="12,0">
                                    <Entry
                                        x:Name="SleepEntry"
                                        Placeholder="7"
                                        Keyboard="Numeric"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2">
                                <Label Text="Exercise" FontSize="12" TextColor="#8A8A8A" />

                                <Border Stroke="#222" StrokeShape="RoundRectangle 14" Padding="12,0">
                                    <Entry
                                        x:Name="ExerciseEntry"
                                        Placeholder="e.g. 30 min"
                                        TextColor="#222222"
                                        PlaceholderColor="#8A8A8A"
                                        BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- MEDICATION -->
                        <VerticalStackLayout>
                            <Label Text="Medication / Supplements" FontSize="12" TextColor="#8A8A8A" />

                            <Border Stroke="#222" StrokeShape="RoundRectangle 14" Padding="12,0">
                                <Entry
                                    x:Name="MedicationEntry"
                                    Placeholder="e.g Vitamin D"
                                    TextColor="#222222"
                                    PlaceholderColor="#8A8A8A"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- NOTES -->
                        <VerticalStackLayout>
                            <Label Text="Notes" FontSize="12" TextColor="#8A8A8A" />

                            <Border Stroke="#222" StrokeShape="RoundRectangle 18" Padding="12">
                                <Editor
                                    x:Name="NotesEditor"
                                    Placeholder="Add any additional notes..."
                                    TextColor="#222222"
                                    PlaceholderColor="#8A8A8A"
                                    HeightRequest="110"
                                    BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- BUTTONS -->
                        <Grid ColumnDefinitions="*,20,*">

                            <Button
                                Grid.Column="0"
                                Text="Cancel"
                                Clicked="OnCancelClicked"
                                BackgroundColor="#D95B74"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="50" />

                            <Button
                                Grid.Column="2"
                                Text="Save"
                                Clicked="OnSaveClicked"
                                BackgroundColor="#E85B73"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="50" />

                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>