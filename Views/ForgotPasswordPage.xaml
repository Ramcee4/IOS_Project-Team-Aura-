<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Team_Aura_Period_Tracker_.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid>

        <VerticalStackLayout
            Padding="30,60,30,30"
            Spacing="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="370">

            <Border
                HeightRequest="92"
                WidthRequest="92"
                HorizontalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 46">

                <Image
                    Source="logo_icon.png"
                    Aspect="AspectFill" />
            </Border>

            <Label
                Text="Period Tracker"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,22,0,0"
                FontSize="25"
                FontAttributes="Bold"
                TextColor="#EA5B73" />

            <Label
                Text="Forgot your password?"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,10,0,0"
                FontSize="14"
                TextColor="#6F6A6C" />

            <Label
                Text="Enter your email and we’ll help you reset your password."
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,8,0,0"
                FontSize="13"
                TextColor="#6F6A6C" />

            <VerticalStackLayout
                Margin="0,38,0,0"
                Spacing="0">

                <Label
                    Text="Email"
                    Margin="0,0,0,8"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#1F1F1F" />

                <Border
                    StrokeThickness="0"
                    BackgroundColor="#F1F1F4"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="48">

                    <Entry
                        x:Name="ResetEmailEntry"
                        Placeholder="Enter your email"
                        PlaceholderColor="#8F8A93"
                        TextColor="#222222"
                        Keyboard="Email"
                        BackgroundColor="Transparent"
                        Margin="14,0" />
                </Border>

                <Button
                    Text="Send Reset Link"
                    Clicked="OnSendResetLinkClicked"
                    Margin="0,20,0,0"
                    HeightRequest="50"
                    CornerRadius="10"
                    BackgroundColor="#E85B73"
                    TextColor="White"
                    FontSize="17"
                    FontAttributes="Bold" />

                <Button
                    Text="Back to Sign In"
                    Clicked="OnBackToSignInClicked"
                    Margin="0,12,0,0"
                    BackgroundColor="Transparent"
                    TextColor="#E85B73"
                    FontAttributes="Bold" />

            </VerticalStackLayout>
            
            

        </VerticalStackLayout>

    </Grid>
</ContentPage>