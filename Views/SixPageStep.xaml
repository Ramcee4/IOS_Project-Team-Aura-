<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Team_Aura_Period_Tracker_.SixPageStep"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4EDEF">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="28,40,28,20"
                Spacing="0"
                HorizontalOptions="Center"
                WidthRequest="390">

                <BoxView HeightRequest="110" Opacity="0" />

                <Border
                    HeightRequest="86"
                    WidthRequest="86"
                    HorizontalOptions="Center"
                    StrokeThickness="0"
                    BackgroundColor="Transparent"
                    StrokeShape="RoundRectangle 43">

                    <Image
                        Source="logo_icon.png"
                        Aspect="AspectFill" />
                </Border>

               
                <Label
                    Text="Period Tracker"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Margin="0,8,0,0"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#EA5B73" />

                <VerticalStackLayout Margin="0,12,0,0" Spacing="6">
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="4">

                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                        <BoxView WidthRequest="38" HeightRequest="4" CornerRadius="2" Color="#6D86FF" />
                    </HorizontalStackLayout>

                    <Label
                        Text="Step 6 of 6"
                        HorizontalOptions="Center"
                        FontSize="12"
                        TextColor="#8F8A93" />
                </VerticalStackLayout>

                <Border
                     Margin="0,18,0,20"
 Padding="19,15,22,24"
 BackgroundColor="#F8F8F8"
 StrokeThickness="0"
 StrokeShape="RoundRectangle 24">
                    
                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="You're All Set!"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#111111" />

                        <Label
                            x:Name="WelcomeDoneLabel"
                            FontSize="14"
                            TextColor="#7A7A7A"
                            LineHeight="1.35" />

                        <Border
                            Padding="16,12"
                            BackgroundColor="#F8F8F8"
                            Stroke="#B8B8B8"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">

                            <VerticalStackLayout Spacing="10">

                                <Label
                                    Text="Next Steps:"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#222222" />

                                <Label
                                    Text="• Log your first daily entry"
                                    FontSize="14"
                                    TextColor="#7A7A7A" />

                                <Label
                                    Text="• Explore the Education Hub"
                                    FontSize="14"
                                    TextColor="#7A7A7A" />

                                <Label
                                    Text="• Review your Privacy Vault settings"
                                    FontSize="14"
                                    TextColor="#7A7A7A" />

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid
             Margin="0,18,0,0"
ColumnDefinitions="*,14,*"
Grid.Row="1"
ColumnSpacing="0"
Padding="28,11,28,75"
           
BackgroundColor="#F4EDEF">

            <Button
                Grid.Column="0"
                Text="Back"
                Clicked="OnBackClicked"
                HeightRequest="50"
                CornerRadius="10"
                BackgroundColor="#C24E63"
                TextColor="White"
                FontSize="17"
                FontAttributes="Bold" />

            <Button
                Grid.Column="2"
                Text="Get Started"
                Clicked="OnGetStartedClicked"
                HeightRequest="50"
                CornerRadius="10"
                BackgroundColor="#E85B73"
                TextColor="White"
                FontSize="17"
                FontAttributes="Bold" />

        </Grid>

    </Grid>
</ContentPage>