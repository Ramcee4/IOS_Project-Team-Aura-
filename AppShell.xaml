<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Team_Aura_Period_Tracker_.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Team_Aura_Period_Tracker_"
    Shell.NavBarIsVisible="False">

    <!-- Mao kini ang mo-load inig abli sa App (SignIn) -->
    <ShellContent
        Title="SignIn"
        ContentTemplate="{DataTemplate local:SignInPage}"
        Route="SignInPage" />

    <!-- Kinahanglan i-define ang HomePage diri para makit-an sa GoToAsync -->
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:HomePage}"
        Route="HomePage" />

</Shell>